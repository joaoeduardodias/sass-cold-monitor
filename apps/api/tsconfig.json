{
  "extends": "@cold-monitor/ts-config/node.json",
  "include": [
    "src/**/*",
    "@types/*.d.ts",
    "prisma.config.ts"
  ],
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
